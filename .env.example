# Copy to .env and fill in. Never commit .env or real keys.

# Django
DJANGO_SECRET_KEY=your-secret-key-here
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_PASSWORD_RESET_TIMEOUT=3600
DJANGO_LOG_LEVEL=DEBUG

# Assistant branding
# ASSISTANT_NAME=Wilfred

# Superuser (dev-only, auto-created on runserver)
DJANGO_USER_NAME=user@example.com
DJANGO_PASSWORD=example-password

# APIs
OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=
# MOONSHOT_API_KEY=
# MOONSHOT_API_BASE=https://api.moonshot.ai/v1/
# BRAVE_SEARCH_API_KEY=
# BRAVE_SEARCH_RPM=50           # Brave Search rate limit (requests/min, default 50)
# BRAVE_API_VERSION=            # Optional: pin Brave Search API version header (YYYY-MM-DD)
# JINA_API_KEY=                  # Jina Reader API key (fallback for web_fetch, PDF parsing)
# JINA_READER_BASE_URL=https://r.jina.ai   # Jina Reader endpoint (eu.r.jina.ai is defunct)
TEST_APIS=False

#LLM-settings:
LLM_ALLOWED_MODELS=openai/gpt-5.5,openai/gpt-5.4,openai/gpt-5.4-mini,openai/gpt-5.4-nano,anthropic/claude-opus-4-8,anthropic/claude-opus-4-7,anthropic/claude-opus-4-6,anthropic/claude-sonnet-4-6,anthropic/claude-haiku-4-5,gemini/gemini-3.1-pro-preview,gemini/gemini-3.5-flash,gemini/gemini-3.1-flash-lite
LLM_DEFAULT_MODEL=openai/gpt-5.4
LLM_DEFAULT_MID_MODEL=openai/gpt-5.4-mini
LLM_DEFAULT_CHEAP_MODEL=openai/gpt-5.4-nano

LLM_REQUEST_TIMEOUT=60
LLM_MAX_RETRIES=2

TRANSCRIPTION_ALLOWED_MODELS=openai/gpt-4o-transcribe,openai/gpt-4o-mini-transcribe,openai/gpt-4o-transcribe-diarize
TRANSCRIPTION_DEFAULT_MODEL=openai/gpt-4o-mini-transcribe
# Optional per-path system defaults. When unset, fall through to
# TRANSCRIPTION_DEFAULT_MODEL. LIVE must be a streaming-capable model.
# TRANSCRIPTION_DEFAULT_MODEL_LIVE=openai/gpt-4o-mini-transcribe
# TRANSCRIPTION_DEFAULT_MODEL_UPLOAD=openai/gpt-4o-transcribe-diarize

# Database (Postgres required for vector search / RAG)
# DATABASE_URL=postgres://user:pass@host:5432/dbname
# PGVECTOR_CONNECTION=postgres://user:pass@host:5432/dbname

# PgBouncer (Heroku / production only — NOT used in local dev).
# On Heroku the pgbouncer buildpack wraps the web/worker dynos via
# bin/start-pgbouncer (see Procfile) and reads these; they have no effect
# locally. See RUNBOOK.md > Database for sizing against the connection cap.
# PGBOUNCER_POOL_MODE=transaction      # must be 'transaction' (matches disable_server_side_cursors)
# PGBOUNCER_DEFAULT_POOL_SIZE=5        # real PG conns per dyno: 5=essential-0 (20), 10=essential-2 (40)
# PGBOUNCER_MAX_CLIENT_CONN=100        # app-side conns to the local pgbouncer (cheap)

# Celery worker tuning (Heroku / production). RERANK_ON_WORKER gates FlashRank
# reranking on the worker (default false) to keep it under the 512 MB dyno cap —
# FlashRank/onnxruntime is ~45 MB resident (TinyBERT model + onnxruntime session).
# Note: this alone won't get a real workload under 512 MB — the shared LLM/ML stack
# (tiktoken ~80 MB + provider clients/embeddings) dominates. Main-chat rerank is controlled
# separately by RERANK_ENABLED (default on). Enable RERANK_ON_WORKER only when the
# worker has memory headroom. MALLOC_ARENA_MAX caps glibc malloc arenas to reduce
# threads-pool fragmentation (Linux/Heroku only; no effect on local Windows dev).
# Both require a worker restart to take effect. See RUNBOOK.md > Worker pool & concurrency.
# RERANK_ON_WORKER=false
# MALLOC_ARENA_MAX=2

# Redis (for Django Channels/WebSocket)
REDIS_URL=redis://127.0.0.1:6379/0

# Email
# Local dev: console backend (default). No DEFAULT_FROM_EMAIL required (defaults to webmaster@localhost).
DJANGO_EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# DEFAULT_FROM_EMAIL=webmaster@localhost

# Production / Staging (e.g. Mailgun): set backend and enable sending. Sandbox = limited recipients; real domain = full delivery.
# DJANGO_EMAIL_BACKEND=anymail.backends.mailgun.EmailBackend
# EMAIL_SENDING_ENABLED=true
# DEFAULT_FROM_EMAIL=noreply@yourdomain.com
# MAILGUN_API_KEY=
# MAILGUN_SENDER_DOMAIN=yourdomain.com
# MAILGUN_API_URL=   # optional, e.g. for region-specific endpoint

# Email verification
EMAIL_VERIFICATION_REQUIRED=True
EMAIL_VERIFICATION_TIMEOUT=86400

# S3 Media Storage (leave AWS_STORAGE_BUCKET_NAME empty for local filesystem)
# AWS_STORAGE_BUCKET_NAME=your-bucket-name
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_REGION_NAME=us-east-1
# AWS_LOCATION=alpha

# Sentry (error tracking & performance monitoring)
# Get your DSN from https://sentry.io → Project Settings → Client Keys
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
# SENTRY_ENVIRONMENT=production
# SENTRY_TRACES_SAMPLE_RATE=1.0
# SENTRY_PROFILES_SAMPLE_RATE=1.0
